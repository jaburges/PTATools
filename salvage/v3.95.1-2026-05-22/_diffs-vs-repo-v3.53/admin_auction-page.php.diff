+                // been sent and orders created.
+                if ($winner || $order) {
+                    $skipped_winner++;
+                    continue;
+                }
+
+                if (in_array($status, array('ended', 'sold'), true)) {
+                    if ($reopen) {
+                        delete_post_meta($pid, '_auction_status');
+                        delete_post_meta($pid, '_auction_ended_at');
+                        $reopened++;
+                    } else {
+                        $skipped_winner++;
